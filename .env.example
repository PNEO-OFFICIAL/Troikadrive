# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ORIGIN_SHARED_SECRET: when set, the server rejects any request that does not
# carry a matching X-Origin-Secret header. Pair with a Cloudflare Transform Rule
# that injects this header so direct-to-origin traffic (bypassing Cloudflare's
# WAF/DDoS) is blocked. Leave unset until the Cloudflare rule is in place.
ORIGIN_SHARED_SECRET=""

# Redis-backed per-IP rate limiting (defense-in-depth behind Cloudflare).
# REDIS_URL is provided by the Railway Redis plugin (reference its variable).
REDIS_URL=""
REDIS_RATE_LIMIT_ENABLED="true"
REDIS_BURST_PER_SEC="10"
REDIS_BAN_SECONDS="600"
